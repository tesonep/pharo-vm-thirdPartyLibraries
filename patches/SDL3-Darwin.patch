+    HandleModifiers(SDL_SCANCODE_RCTRL, modifierFlags);
+    HandleModifiers(SDL_SCANCODE_RALT, modifierFlags);
+    HandleModifiers(SDL_SCANCODE_RGUI, modifierFlags);
